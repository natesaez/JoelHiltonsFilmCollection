@{
}

@model List<NewMovie>
<table class="table table-bordered">
    <thead class="fw-bolder">
        <td>Title</td>
        <td>Year</td>
        <td>Category</td>
        <td>Director</td>
        <td>Rating</td>
        <td>Edited</td>
        <td>LentTo</td>
        <td>CopiedToPlex</td>
        <td>Notes</td>
    </thead>
    
    @foreach (var app in Model)
    {
        <tbody>
        
            <td>@app.Title</td>
            <td>@app.Year</td>
            <td>@app.CategoryId</td>
            <td>@app.Director</td>
            <td>@app.Rating</td>
            <td>@app.Edited</td>
            <td>@app.LentTo</td>
            <td>@app.CopiedToPlex</td>
            <td>@app.Notes</td>

            <td><a class="btn btn-info" asp-controller="Home" asp-action="Edit" asp-route-id="@app.MovieId">Edit</a></td>
            <td><a class="btn btn-danger" asp-controller="Home" asp-action="Delete" asp-route-id="@app.MovieId">Delete</a></td>
        
        </tbody>
    }
</table>